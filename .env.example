# Base
NODE_ENV=development

# Backend
BACKEND_PORT=3000
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://prodexa:prodexa@localhost:55432/prodexa?schema=public

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Opcional: sin esta variable, Sentry no se inicializa (cero llamadas de red) —
# desarrollo local no necesita una cuenta de Sentry. Conseguir el DSN creando un
# proyecto Next.js en https://sentry.io.
NEXT_PUBLIC_SENTRY_DSN=

# Postgres
POSTGRES_DB=prodexa
POSTGRES_USER=prodexa
POSTGRES_PASSWORD=prodexa
