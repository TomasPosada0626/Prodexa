generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Formulation {
  id                String           @id @default(cuid())
  nombreProducto    String
  registroSanitario String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  ingredientes      Ingredient[]
  pasosPreparacion  PreparationStep[]
}

model Ingredient {
  id                String      @id @default(cuid())
  formulationId     String
  nombre            String
  porcentaje        Decimal     @db.Decimal(10, 4)
  cantidadGramosBase Decimal    @db.Decimal(14, 4)
  cantidadKg        Decimal     @db.Decimal(14, 6)
  precioKg          Decimal     @db.Decimal(14, 2)
  precioTotal       Decimal     @db.Decimal(14, 2)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  formulation       Formulation @relation(fields: [formulationId], references: [id], onDelete: Cascade)

  @@index([formulationId])
}

model PreparationStep {
  id            String      @id @default(cuid())
  formulationId String
  orden         Int
  descripcion   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  formulation   Formulation @relation(fields: [formulationId], references: [id], onDelete: Cascade)

  @@index([formulationId, orden])
}
