BACKEND_PORT=3000
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://prodexa:prodexa@localhost:55432/prodexa?schema=public

# Autenticacion (generar valores propios con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=changeme-access-secret
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
COOKIE_SECURE=false
# En local, dejar en 'lax' (mismo sitio: localhost:3000 y localhost:3001). En
# produccion con frontend y backend en dominios distintos (ej. Vercel + Render sin
# dominio propio compartido), poner 'none' — y COOKIE_SECURE=true es obligatorio en
# ese caso, el navegador rechaza SameSite=None sin Secure.
COOKIE_SAMESITE=lax

# Carpeta donde quedan las imagenes subidas (editor de preparacion de formulaciones).
# Por defecto: ./uploads relativo al directorio de trabajo del backend.
UPLOADS_DIR=
