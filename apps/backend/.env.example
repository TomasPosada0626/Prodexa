BACKEND_PORT=3000
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://prodexa:prodexa@localhost:55432/prodexa?schema=public

# Autenticacion (generar valores propios con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=changeme-access-secret
JWT_REFRESH_SECRET=changeme-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=30
COOKIE_SECURE=false
# En local, dejar en 'lax' (mismo sitio: localhost:3000 y localhost:3001). En
# produccion con frontend y backend en dominios distintos (ej. Vercel + Render sin
# dominio propio compartido), poner 'none' — y COOKIE_SECURE=true es obligatorio en
# ese caso, el navegador rechaza SameSite=None sin Secure.
COOKIE_SAMESITE=lax

# Carpeta donde quedan las imagenes subidas (editor de preparacion de formulaciones).
# Por defecto: ./uploads relativo al directorio de trabajo del backend. Se usa solo
# si las 5 variables R2_* de abajo no estan todas presentes.
UPLOADS_DIR=

# Envio de correo (recuperacion de contrasena). Sin RESEND_API_KEY, el codigo se
# loguea en la consola del backend en vez de enviarse — desarrollo local no necesita
# una cuenta de Resend. Conseguir la key en https://resend.com.
RESEND_API_KEY=
MAIL_FROM=Prodexa <onboarding@resend.dev>

# Almacenamiento de imagenes en Cloudflare R2 (S3-compatible). Si estas 5 no estan
# TODAS presentes, se usa disco local (UPLOADS_DIR) — no se necesita cuenta de
# Cloudflare en desarrollo. Si solo algunas estan seteadas, el backend falla al
# iniciar en vez de perder imagenes en produccion silenciosamente.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Limite de requests/min para register/login/change-password/forgot-password/
# reset-password. Sin esta variable, el default real es 5 (produccion). Solo se
# sube en CI para que la suite E2E de Playwright pueda correr sin chocar con el
# limite real.
AUTH_THROTTLE_LIMIT=
